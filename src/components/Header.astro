---
// Sticky site header: name and role on the left, primary nav on the right.
import { profile } from '../lib/facts';
import { withBase } from '../lib/paths';

// external marks the off-site links, which get target=_blank and rel=noopener
// below. The mailto stays in the same tab.
const links = [
  { label: 'GitHub', href: profile.links.github, external: true },
  { label: 'Resume', href: withBase(profile.links.resume), external: true },
  { label: 'Email', href: `mailto:${profile.links.email}`, external: false },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__id" href={withBase('/')}>
      <span class="site-header__name">{profile.name}</span>
      <span class="site-header__role mono">{profile.role}</span>
    </a>
    <nav class="site-header__nav mono" aria-label="Primary">
      {
        links.map((l) => (
          <a
            class="link"
            href={l.href}
            {...l.external ? { target: '_blank', rel: 'noopener' } : {}}
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: var(--border);
    background: var(--ink-900); /* fallback for browsers without color-mix */
    background: color-mix(in srgb, var(--ink-900) 88%, transparent);
    position: sticky;
    top: 0;
    z-index: 10;
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    padding-block: var(--space-3);
  }
  .site-header__id {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    min-width: 0;
  }
  .site-header__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-1);
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .site-header__role {
    font-size: var(--step--1);
    color: var(--text-500);
    white-space: nowrap;
  }
  .site-header__nav {
    display: flex;
    gap: var(--space-5);
    font-size: var(--step--1);
  }
  @media (max-width: 34rem) {
    .site-header__role {
      display: none;
    }
    .site-header__nav {
      gap: var(--space-4);
    }
  }
</style>

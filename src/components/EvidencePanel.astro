---
// Evidence section of a project case study: the measured metrics table, the
// skills-with-evidence list, and the repo and demo links.
import type { Project } from '../lib/facts';
import { skillsForProject } from '../lib/facts';

interface Props {
  project: Project;
}
const { project } = Astro.props;
// A skill lands here only if it carries a concrete evidence string for this
// project, the same rule the graph edges follow.
const evidence = skillsForProject(project.id);
const metrics = project.metrics ?? [];
---

<section class="evidence" aria-labelledby="evidence-h">
  <h2 id="evidence-h" class="evidence__h mono">Evidence</h2>

  {
    metrics.length > 0 && (
      <div class="panel evidence__metrics">
        <div class="panel__cap">
          <span>measured</span>
          <span aria-hidden="true">{project.label}</span>
        </div>
        <dl class="metrics">
          {metrics.map((m) => (
            <div class="metrics__row">
              <dt class="metrics__label mono">{m.label}</dt>
              <dd class="metrics__val-wrap">
                <span class="metrics__val mono">{m.value}</span>
                {m.note && <span class="metrics__note">{m.note}</span>}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    )
  }

  <div class="panel evidence__skills">
    <div class="panel__cap">
      <span>skills</span>
      <span aria-hidden="true">{evidence.length}</span>
    </div>
    <ul class="ev-list">
      {
        evidence.map(({ skill, evidence: ev }) => (
          <li class="ev-list__item" data-cat={skill.category}>
            <span class="ev-list__skill mono">
              <span class="dot" aria-hidden="true" />
              {skill.label}
            </span>
            <span class="ev-list__ev">{ev}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="evidence__links mono">
    <a class="btn" href={project.repo} target="_blank" rel="noopener">
      View repository
      <span aria-hidden="true">&#8599;</span>
    </a>
    {
      project.demo && (
        <a class="btn btn--ghost" href={project.demo.url} target="_blank" rel="noopener">
          {project.demo.label}
          <span aria-hidden="true">&#8599;</span>
        </a>
      )
    }
  </div>
</section>

<style>
  .evidence {
    margin-top: var(--space-8);
    display: grid;
    gap: var(--space-5);
  }
  .evidence__h {
    font-weight: 500;
    font-size: var(--step-0);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--signal-500);
    padding-bottom: var(--space-2);
    border-bottom: var(--border);
  }

  .metrics {
    padding: var(--space-2) 0;
  }
  .metrics__row {
    display: grid;
    grid-template-columns: minmax(9rem, 14rem) 1fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-top: var(--border);
  }
  .metrics__row:first-child {
    border-top: none;
  }
  .metrics__label {
    font-size: var(--step--1);
    color: var(--text-500);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding-top: 0.15rem;
  }
  .metrics__val-wrap {
    display: grid;
    gap: var(--space-1);
  }
  .metrics__val {
    font-size: var(--step-1);
    font-weight: 500;
    color: var(--text-100);
  }
  .metrics__note {
    font-size: var(--step--1);
    color: var(--text-300);
    line-height: 1.5;
  }

  .ev-list {
    display: grid;
  }
  .ev-list__item {
    display: grid;
    grid-template-columns: minmax(9rem, 13rem) 1fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-top: var(--border);
    /* Align the skill name to the evidence's first line. Without this the row
       stretches to the tallest cell and the dot drops to the middle. */
    align-items: baseline;
  }
  .ev-list__item:first-child {
    border-top: none;
  }
  .ev-list__skill {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    font-size: var(--step-0);
    color: var(--text-100);
  }
  .ev-list__skill .dot {
    background: var(--cat);
    align-self: center;
  }
  .ev-list__ev {
    color: var(--text-300);
    font-size: var(--step-0);
  }

  .evidence__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  @media (max-width: 40rem) {
    .metrics__row,
    .ev-list__item {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
